# Local configuration (contains DB credentials & secrets)
/config/config.php

# Uploaded files & generated artifacts
/storage/uploads/*
!/storage/uploads/.gitkeep
/storage/reports/*
!/storage/reports/.gitkeep
/storage/tmp/*
!/storage/tmp/.gitkeep

# Note: /vendor holds manually-vendored libraries (FPDF, QR) and IS committed,
# since Composer is unavailable on the target shared hosting.

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Logs
*.log
